{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"strict": true,
		"skipLibCheck": true,
		"esModuleInterop": true,
		"allowSyntheticDefaultImports": true,
		"types": ["node"],
		"outDir": "./dist",
		"plugins": [
      		{
        		"name": "workflow"
      		}
    	]
	},
	"exclude": ["node_modules"]
}
